{
  "name": "luharide-backend",
  "version": "1.0.0",
  "description": "Backend API for LuhaRide - Uttarakhand Taxi Booking Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:gateway": "node gateway/server.js",
    "start:ms:auth": "node microservices/authService.js",
    "start:ms:core": "node microservices/coreService.js",
    "start:ms:union": "node microservices/unionService.js",
    "start:ms:platform": "node microservices/platformService.js",
    "develop:luharide-microservices-local-five-services": "cross-env GATEWAY_PORT=3010 concurrently -k -n auth,core,union,plat,gw -c green,yellow,magenta,cyan,blue \"node microservices/authService.js\" \"node microservices/coreService.js\" \"node microservices/unionService.js\" \"node microservices/platformService.js\" \"node gateway/server.js\"",
    "verify:luharide-microservices-health-endpoints": "cross-env GATEWAY_PORT=3010 node scripts/verify-luharide-microservices-health-endpoints.js",
    "phase1:dryrun:vps": "bash scripts/vps-gateway-first-dry-run.sh",
    "verify:phase2-env": "node scripts/verify-phase2-env.js",
    "phase4:verify:stack": "node scripts/verify-phase4-production-stack.js",
    "check:ms": "npm run verify:luharide-microservices-health-endpoints",
    "check:local-ms": "node scripts/check-local-microservices.js",
    "dev:stack": "npm run develop:luharide-microservices-local-five-services",
    "dev": "nodemon server.js",
    "migrate": "node migrations/run-migrations.js",
    "seed": "node seeders/run-seeders.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test-db": "node test-connection.js",
    "setup-db": "node setup-database.js"
  },
  "keywords": [
    "taxi",
    "booking",
    "uttarakhand",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "aws-sdk": "^2.1529.0",
    "axios": "^1.6.5",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^3.0.3",
    "ioredis": "^5.10.1",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.8",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.3",
    "qrcode": "^1.5.3",
    "rate-limit-redis": "^4.3.1",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
