# =============================================================================
# LuhaRide backend — COPY this file to `.env` and fill real values.
# Never commit `.env` (secrets). This file IS safe to push to GitHub.
#
# VPS / production minimum:
#   NODE_ENV=production
#   TRUST_PROXY=1          ← required behind nginx (else rate limits = 1 IP for everyone)
#   DB_* + JWT_SECRET + EMAIL_* + CLIENT_URL (your app / site URL for CORS)
# =============================================================================

# --- Server ---
# Local dev: development. VPS: production (enables TRUST_PROXY warning if missing).
NODE_ENV=development
PORT=3000
# App / web origin for CORS + Socket.IO (production: https://yourdomain.com or app scheme)
CLIENT_URL=http://localhost:3000
# Optional comma-separated allowlist (recommended in production).
# Example: CORS_ALLOWED_ORIGINS=https://luharide.in,https://admin.luharide.in
# Static website (login/signup from browser): add root domain + www
# Example: CORS_ALLOWED_ORIGINS=https://luharide.cloud,https://www.luharide.cloud
CORS_ALLOWED_ORIGINS=

# --- Microservices mode (optional; monolith default = single `node server.js`) ---
# 4 services + 1 API Gateway — same REST paths as monolith; Flutter points to gateway only.
# Run locally:  npm run develop:luharide-microservices-local-five-services  (gateway **3010** — not 3000)
# Flutter local + this stack:  --dart-define=USE_LOCAL_API=true --dart-define=LOCAL_API_PORT=3010
# Docker:  docker compose -f infra/docker-compose-luharide-backend-microservices-redis-stack.yml up
# Docs: ../docs/LUHARIDE_MICROSERVICES_MIGRATION_STEP_BY_STEP.md , ../docs/MICROSERVICES_RUN.md
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
CORE_SERVICE_PORT=3002
UNION_SERVICE_PORT=3003
PLATFORM_SERVICE_PORT=3004
AUTH_URL=http://127.0.0.1:3001
CORE_URL=http://127.0.0.1:3002
UNION_URL=http://127.0.0.1:3003
PLATFORM_URL=http://127.0.0.1:3004
# Optional: Flutter web / marketing site URL. When someone opens the API base URL in a browser tab,
# gateway GET / redirects there (curl/scripts still receive JSON). Production example: https://luharide.cloud
PUBLIC_WEB_APP_URL=

# --- Database (required) ---
# WHO FILLS: You — on your machine or VPS, in the real file `backend/.env` (not in Git).
# WHAT: Same password PostgreSQL user uses. Production: NODE_ENV=production ⇒ empty DB_PASSWORD = server will exit at startup.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=luharide
DB_USER=postgres
DB_PASSWORD=your_password

# --- PostgreSQL pool (per PM2 process) — KVM/small VPS: often leave defaults or PG_POOL_MAX=15–20 ---
PG_POOL_MIN=2
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=10000
# 0 = disabled (local dev). Production VPS: set 25000–30000 to abort runaway queries.
PG_STATEMENT_TIMEOUT_MS=0

# --- HTTP server (Node socket timeout) ---
HTTP_SERVER_TIMEOUT_MS=120000

# --- Optional read replica (only if DB_READ_HOST != DB_HOST) ---
# DB_READ_HOST=
# DB_READ_PORT=
# DB_READ_USER=
# DB_READ_PASSWORD=
# DB_READ_NAME=
# PG_POOL_READ_MIN=2
# PG_POOL_READ_MAX=40

# --- Reverse proxy (nginx / Cloudflare) — production behind HTTPS proxy ---
# Values: 1 | true | yes | on → trust 1 hop. 0 | false | no | off → disable.
# 2–32 → multiple proxies (e.g. Cloudflare + nginx). See src/config/trustProxy.js
# PM2 ecosystem sets TRUST_PROXY=1 by default for microservices; override with TRUST_PROXY=0 if only direct :3000.
TRUST_PROXY=1

# --- Global API rate limit (ALL /api/* share one bucket per client IP) ---
# Window default 15 min if unset; max default 500.
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=500
# Legacy aliases (used if API_* unset):
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=500

# --- Simple-auth extra limits (email/password routes, per IP, ON TOP of global limit) ---
# Login: failed attempts per 15 min | Signup / forgot / change: per hour | Reset: failed per 15 min
SIMPLE_AUTH_LOGIN_MAX=15
SIMPLE_AUTH_SIGNUP_MAX=10
SIMPLE_AUTH_FORGOT_MAX=5
SIMPLE_AUTH_RESET_MAX=12
SIMPLE_AUTH_CHANGE_PASSWORD_MAX=10

# --- JWT (production: unique random string, min 16 chars; not the placeholder below) ---
# WHO FILLS: You — only in `backend/.env` on server/PC. AI/repo cannot store your real secret.
# Verify Phase-2 env (JWT + DB rules) after editing .env:  npm run verify:phase2-env
# HOW: Replace the line below with a long random string (e.g. run:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Reject: default placeholders (see src/config/env.js) — use a new random value, then `pm2 restart all`.
# Optional override for minimum length check (default 16) if your existing secret is shorter:
# JWT_SECRET_MIN_LENGTH=16
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=30d

# --- Logging ---
LOG_LEVEL=info

# --- Admin bootstrap (union_admin role for this email) ---
ADMIN_EMAIL=orahulpanwar@gmail.com

# --- Email OTP / SMTP (Gmail: App Password) ---
EMAIL_USER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_FROM=LuhaRide <noreply@luharide.com>

# --- Phone OTP (optional) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# --- Google Maps (optional) ---
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# --- Razorpay (optional) ---
# Keep false until online payment feature is launched.
PAYMENTS_ENABLED=false
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# --- AWS S3 uploads (optional) ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=luharide-documents

# --- FCM (optional) ---
FCM_SERVER_KEY=your_fcm_server_key

# --- Redis (Phase next — multi-instance rate limits + Socket.IO) ---
# false = in-memory rate limits; single-node Socket.IO only
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# Optional: override service name in logs (defaults: luha-monolith, luha-gateway, luha-ms-auth, …)
# LUHA_SERVICE_NAME=my-custom-name

# -----------------------------------------------------------------------------
# /api/auth OTP (phone or email) — layered limits:
#   Per IP: send-otp 3/hour, verify-otp failures 5/15 min (see rateLimiter.js)
#   Per phone/email (extra): tunable below
# -----------------------------------------------------------------------------
OTP_SEND_IDENT_WINDOW_MS=3600000
OTP_SEND_IDENTIFIER_MAX=3
OTP_VERIFY_IDENTIFIER_MAX=8

# Authenticated KYC uploads (/api/uploads/*) per user per hour
UPLOAD_DOC_MAX_PER_HOUR=30

# Union PDF poster GETs per union_admin per minute (CPU-heavy)
UNION_POSTER_MAX_PER_MINUTE=15
